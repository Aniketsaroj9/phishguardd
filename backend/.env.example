# Copy to .env for local overrides, or set these as environment
# variables in your hosting platform (Render/Railway/etc).

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=phishguard_db

# Flask
FLASK_DEBUG=false
HOST=0.0.0.0
PORT=5000

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=https://your-frontend.netlify.app
